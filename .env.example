# OpenClaw websocket gateway address
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw operator token (required if auto-discovery cannot find one locally)
OPENCLAW_TOKEN=

# Optional: custom session key. If empty, Yuzhua will auto-generate and persist one.
OPENCLAW_SESSION_KEY=

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=small

# Optional huggingface mirror endpoint, e.g. https://hf-mirror.com
HF_ENDPOINT=
